# Copy this file to .env and fill in your values.
# .env is in .gitignore and must never be committed.

# Required for Agent 7 (Orchestrator) to generate Claude-authored board briefs.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Azure Blob Storage (future integration — Synapse writes CSVs here nightly)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=radisson-ci

# Optional: Reltio MDM API (future integration — property master data)
RELTIO_API_URL=
RELTIO_API_KEY=
